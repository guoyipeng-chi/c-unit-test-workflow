{
  "project": {
    "name": "C Unit Test Workflow",
    "version": "1.0",
    "description": "LLM-based C unit test generation with vLLM and Qwen3 Coder"
  },
  
  "llm": {
    "backend": "auto",
    "backend_comment": "可选: auto / vllm / ollama。auto=优先vLLM，失败回退Ollama",
    "api_base": "http://localhost:8000",
    "api_base_comment": "可通过环境变量 VLLM_API_BASE 覆盖",
    "remote_examples": {
      "local": "http://localhost:8000",
      "remote_server": "http://192.168.1.100:8000",
      "cloud_server": "http://your-server.com:8000"
    },
    "model": "qwen-coder",
    "model_comment": "vLLM模型名（仅backend=vllm或auto命中vllm时使用）",
    "temperature": 0.7,
    "max_tokens": 64000,
    "top_p": 0.95,
    "timeout": 120,

    "ollama": {
      "api_base": "http://localhost:11434",
      "model": "gpt-oss:120b-cloud",
      "timeout": 900,
      "max_tokens": 64000,
      "fallback_from_vllm": true,
      "comment": "可改为gpt-oss:120b-cloud等Ollama可用模型"
    }
  },
  
  "code_analysis": {
    "include_patterns": ["*.h"],
    "source_patterns": ["*.c"],
    "exclude": [
      "**/third_party/**",
      "**/build/**",
      "**/.git/**"
    ]
  },
  
  "test_generation": {
    "framework": "gtest",
    "output_suffix": "_llm_test.cpp",
    "include_mocks": true,
    "coverage_goal": 80,
    "quality_gates": {
      "enabled": true,
      "strict": false,
      "tools": ["clang-format", "clang-tidy", "cppcheck"]
    },
    "compile_fix": {
      "auto_fix_compile_errors": true,
      "max_fix_attempts": 2,
      "auto_fix_test_failures": true,
      "max_test_fix_attempts": 2,
      "llm_triage_enabled": true,
      "triage_min_confidence": 0.55,
      "web_research_enabled": true,
      "web_research_max_results": 4,
      "comment": "quickstart/ut_workflow透传：编译失败与运行失败的自动修复开关/次数（独立计数），以及先LLM诊断再修复与最低置信度阈值"
    },
    "test_cases_per_function": {
      "minimum": 5,
      "recommended": 10
    }
  },
  
  "compile_commands": {
    "search_paths": [
      "./build/compile_commands.json",
      "./build-ninja-msvc/compile_commands.json",
      "./cmake-build-debug/compile_commands.json"
    ]
  },

  "build": {
    "compiler": "",
    "compiler_comment": "可选：g++ / clang++ / cl 或编译器绝对路径。留空则自动检测",
    "auto_install_on_missing": true,
    "auto_install_comment": "仅交互模式生效；Windows下会尝试用winget安装LLVM(clang++)"
  },

  "paths": {
    "project_root": ".",
    "project_root_comment": "被测试代码的根路径，相对于此配置文件的位置，或绝对路径",
    "examples": {
      "current": ".",
      "relative": "../my-project",
      "absolute_linux": "/home/user/projects/my-c-project",
      "absolute_windows": "C:\\Users\\YourName\\my-c-project"
    },
    
    "test_output_dir": "test",
    "test_output_dir_comment": "生成的测试用例存放目录，相对于 project_root",
    
    "include_dir": "include",
    "include_dir_comment": "头文件目录，相对于 project_root",
    
    "src_dir": "src",
    "src_dir_comment": "源文件目录，相对于 project_root"
  }
}
